# Magic phrase used as login password
MAGIC=your-secret-magic-phrase

# Secret used to sign session cookies (use a long random string)
SESSION_SECRET=your-long-random-session-secret

# Port to listen on (default: 3000)
PORT=3000

# Set to 'production' to enable secure cookies (requires HTTPS via reverse proxy)
NODE_ENV=production

# Delay in milliseconds between slides (default: 1000)
SLIDE_DELAY=1000

# Delay in milliseconds after the presentation ends before redirecting (default: 3000)
PRESENTATION_END_DELAY=3000
